{
  "name": "anyfeast-nutritionist-backend",
  "version": "0.1.0",
  "private": true,
  "description": "AnyFeast nutritionist backend (Node.js + Postgres). Replaces the FastAPI + Firestore backend.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed:all",
    "db:create-schema": "tsx src/db/scripts/create-schema.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.4",
    "@sentry/node": "^8.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mjml": "^4.15.3",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "pino-http": "^10.2.0",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.3",
    "sequelize-typescript": "^2.1.6",
    "sharp": "^0.33.4",
    "twilio": "^5.2.2",
    "uuid": "^10.0.0",
    "winston": "^3.13.1",
    "zod": "^3.23.8",
    "@asteasolutions/zod-to-openapi": "^7.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mjml": "^4.7.4",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0",
    "testcontainers": "^10.10.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}
