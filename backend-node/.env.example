# --- Server ---
NODE_ENV=development
PORT=8000
LOG_LEVEL=info

# --- CORS ---
# Comma-separated list of allowed origins (no spaces). Wildcard not allowed in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://anyfeast:anyfeast@localhost:5432/anyfeast
DB_SCHEMA=nutritionist
DB_SSL=false

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_ACCESS_SECRET=replace_me_with_long_random_string
JWT_REFRESH_SECRET=replace_me_with_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Email (SendGrid) ---
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=noreply@anyfeast.com
EMAIL_FROM_NAME=AnyFeast

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_SECRET=

# --- Storage (Supabase) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=anyfeast-nutritionist

# --- Python AI services ---
AI_SERVICE_URL=http://localhost:9000
AI_SERVICE_TIMEOUT_MS=30000

# --- Sentry ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- n8n webhook ---
N8N_WEBHOOK_SECRET=
